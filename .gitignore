# macOS
.DS_Store
.AppleDouble
.LSOverride

# Xcode
#
# Per-user Xcode state. These change on every project open/build and should
# never be shared — they only create noise in diffs and merge conflicts.
*.xcuserstate
xcuserdata/
*.xcscmblueprint
*.xccheckout

# Swift Package Manager
.swiftpm/
.build/
Package.resolved

# Build products
build/
DerivedData/

# CocoaPods
Pods/

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output
